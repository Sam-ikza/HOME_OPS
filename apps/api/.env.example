# HomeSense API environment template (safe to commit)

# App
APP_NAME=HomeSense AI API
ENVIRONMENT=development
DEBUG=false
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database
# Use PostgreSQL in production. Example:
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=sqlite:///./data/homeops.db

# Auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=45
REFRESH_TOKEN_MINUTES=4320

# AI Providers
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.1-8b-instant
GROQ_DIAGNOSIS_MODEL=llama-3.1-8b-instant
GOOGLE_API_KEY=
COHERE_API_KEY=
OPENAI_API_KEY=

# Vector
VECTOR_PROVIDER=pinecone_fallback
PINECONE_API_KEY=
PINECONE_INDEX=homesense-manuals

# External APIs
RAINFOREST_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Safety and scheduling
WARRANTY_DAYS=365
SCHEDULER_ENABLED=true
TOOL_CALLS_ENABLED=true
DANGER_ESCALATION_TEXT=DANGER: This repair involves high-voltage, gas lines, or sealed internal components. DO NOT attempt to fix this yourself as it poses a severe safety risk. Click the button below to instantly forward this diagnostic report to a vetted local professional.
SOFTWARE_LOCK_HINTS=Samsung Family Hub Refrigerators,Modern Bosch 800-Series Dishwashers,LG SmartWash Combos,Apple/Nest Smart Home hubs,John Deere riding mowers/tractors
